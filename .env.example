# Meeting Bot Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================

# Telegram Bot token from @BotFather
# Get it at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
TELEGRAM_USER_ID=your_user_id_here

# Google Gemini API key
# Get it at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Bitrix24 inbound webhook URL
# Create at: Bitrix24 > Automation > Webhooks
BITRIX_WEBHOOK_URL=https://your-bitrix24.rest/id/webhook

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# Whisper model: tiny, base, small, medium, large
# Larger = more accurate but slower
WHISPER_MODEL=base

# Audio device for recording
# Windows: "CABLE Output (VB-Audio Virtual Cable)"
# Linux: "pulse" or "default"
# macOS: "BlackHole 2ch"
AUDIO_DEVICE=pulse

# Maximum meeting duration in seconds (default: 1 hour)
MEETING_TIMEOUT=3600

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Redis URL for rate limiting (optional but recommended for production)
REDIS_URL=redis://localhost:6379

# CORS allowed origins (comma-separated, use * for all in development)
ALLOWED_ORIGINS=*

# Environment: development or production
ENVIRONMENT=development

# ===========================================
# NOTES
# ===========================================
# - Never commit .env file to version control
# - Keep your API keys secret
# - Rotate keys regularly
# - Use strong passwords for production
